    <style>
        :root {
    --bg-primary: #0a0a0f;
    --bg-secondary: #121228;
    --surface: rgba(255, 255, 255, 0.03);
    --surface-hover: rgba(255, 255, 255, 0.08);
    --accent-primary: #00f5ff;
    --accent-secondary: #7c3aed;
    --accent-gold: #fbbf24;
    --text-primary: #f8fafc;
    --text-secondary: #94a3b8;
    --text-muted: #64748b;
    --border: rgba(255, 255, 255, 0.1);
    --glow-primary: rgba(0, 245, 255, 0.25);
    --glow-secondary: rgba(124, 58, 237, 0.25);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
    scroll-padding-top: 80px;
}

body {
    font-family: 'Inter', sans-serif;
    background: var(--bg-primary);
    color: var(--text-primary);
    overflow-x: hidden;
    line-height: 1.7;
}

/* Floating Background Orbs */
.particles {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
}

.particle {
    position: absolute;
    border-radius: 50%;
    animation: float 25s infinite linear;
}

@keyframes float {
    0% { 
        transform: translateY(100vh) scale(0);
        opacity: 0; 
    }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { 
        transform: translateY(-100px) scale(1);
        opacity: 0; 
    }
}

/* Navigation */
.nav-container {
    position: fixed;
    top: 0;
    width: 100%;
    padding: 1.5rem 5%;
    backdrop-filter: blur(25px);
    background: rgba(10, 10, 15, 0.9);
    border-bottom: 1px solid var(--border);
    z-index: 1000;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.nav-content {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    font-size: 1.8rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.nav-links {
    display: flex;
    list-style: none;
    gap: 2.5rem;
    align-items: center;
}

.nav-link {
    position: relative;
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.3s ease;
    padding: 0.5rem 0;
}

.nav-link::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent-primary), var(--accent-gold));
    transition: width 0.3s ease;
}

.nav-link:hover::before,
.nav-link.active::before {
    width: 100%;
}

.nav-link:hover {
    color: var(--text-primary);
}

.mode-toggle {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    padding: 0.7rem;
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 1.1rem;
}

.mode-toggle:hover {
    background: var(--accent-primary);
    color: var(--bg-primary);
    transform: scale(1.1);
}

/* Hero Section */
.hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 0 5%;
}

.hero-content {
    max-width: 1200px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8rem;
    align-items: center;
}

.hero-main h1 {
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, var(--text-primary) 0%, var(--accent-primary) 50%, var(--accent-gold) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.subtitle {
    font-size: 1.3rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-weight: 400;
}

.cta-buttons {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
}

.cta-primary, .cta-secondary, .submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1.2rem 2.5rem;
    text-decoration: none;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    border: none;
    cursor: pointer;
    font-family: inherit;
}

.cta-primary {
    background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-gold) 100%);
    color: var(--bg-primary);
    box-shadow: 0 20px 40px var(--glow-primary);
}

.cta-secondary {
    border: 2px solid var(--accent-primary);
    color: var(--accent-primary);
    background: transparent;
}

.cta-primary:hover, .submit-btn:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 30px 60px var(--glow-primary);
}

.cta-secondary:hover {
    background: var(--accent-primary);
    color: var(--bg-primary);
    transform: translateY(-5px);
}

.profile-container {
    display: flex;
    justify-content: center;
    position: relative;
}

/* Replace ONLY the profile-ring section in your styles.css */

/* PERFECT PROFILE IMAGE - Matches your screenshot exactly */
.profile-container {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    height: 350px; /* Perfect size like your screenshot */
}

.profile-ring {
    /* REMOVED ALL ROTATION - Static elegant frame */
    width: 340px;
    height: 340px;
    border-radius: 50%;
    /* Subtle gradient border like your screenshot */
    border: 6px solid transparent;
    background: linear-gradient(45deg, 
        rgba(0, 245, 255, 0.3) 0%, 
        rgba(251, 191, 36, 0.2) 50%, 
        rgba(124, 58, 237, 0.2) 100%
    ) border-box;
    background-clip: content-box, border-box;
    padding: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Subtle breathing glow - matches screenshot */
    box-shadow: 
        0 0 40px rgba(0, 245, 255, 0.4),
        0 20px 60px rgba(0, 0, 0, 0.8),
        inset 0 0 40px rgba(0, 0, 0, 0.6);
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    /* NO ANIMATION - Static like screenshot */
    animation: none;
}

.profile-img {
    width: 320px;  /* Large like your screenshot */
    height: 320px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center; /* Perfect face centering */
    /* Perfect shadows matching screenshot */
    box-shadow: 
        0 0 30px rgba(0, 245, 255, 0.6),
        inset 0 0 30px rgba(0, 0, 0, 0.7);
    transition: all 0.5s ease;
    border: 3px solid rgba(255, 255, 255, 0.2);
}

.profile-img:hover {
    /* Subtle lift on hover */
    transform: scale(1.03) translateY(-5px);
    box-shadow: 
        0 0 60px rgba(0, 245, 255, 0.8),
        0 0 100px rgba(124, 58, 237, 0.4),
        inset 0 0 40px rgba(0, 0, 0, 0.8);
}



/* Sections */
section {
    padding: 120px 5%;
    max-width: 1400px;
    margin: 0 auto;
}

.section-header {
    text-align: center;
    margin-bottom: 5rem;
}

.section-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
    position: relative;
}

.section-title::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 4px;
    background: linear-gradient(90deg, var(--accent-primary), var(--accent-gold));
    border-radius: 2px;
}

/* About Section */
.about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
}

.about-text h3 {
    font-size: 1.8rem;
    color: var(--accent-primary);
    margin-bottom: 1.5rem;
    font-weight: 700;
}

.about-text p {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
}

.stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
}

.stat-card {
    background: var(--surface);
    padding: 2.5rem 2rem;
    border-radius: 24px;
    border: 1px solid var(--border);
    backdrop-filter: blur(20px);
    text-align: center;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
}

.stat-card:hover {
    transform: translateY(-15px) scale(1.03);
    background: var(--surface-hover);
    box-shadow: 0 30px 60px var(--glow-primary);
}

.stat-number {
    font-size: 3rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
}

/* Skills */
.skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
}

.skill-card {
    background: var(--surface);
    padding: 3rem 2.5rem;
    border-radius: 24px;
    border: 1px solid var(--border);
    backdrop-filter: blur(20px);
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
}

.skill-card:hover {
    transform: translateY(-25px);
    box-shadow: 0 40px 80px var(--glow-primary);
}

.skill-icon {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-gold));
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    font-size: 2rem;
    color: var(--bg-primary);
    transition: all 0.3s ease;
}

.skill-card:hover .skill-icon {
    transform: scale(1.1) rotate(10deg);
}

/* Timeline */
.timeline {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
}

.timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 100%;
    background: linear-gradient(to bottom, var(--accent-primary), var(--accent-secondary));
    z-index: 0;
}

.timeline-item {
    display: flex;
    margin-bottom: 4rem;
    position: relative;
    z-index: 1;
}

.timeline-item:nth-child(odd) {
    justify-content: flex-end;
    padding-left: 0;
    padding-right: 4rem;
}

.timeline-item:nth-child(even) {
    justify-content: flex-start;
    padding-right: 0;
    padding-left: 4rem;
}

.timeline-content {
    width: 45%;
    background: var(--surface);
    padding: 2.5rem;
    border-radius: 24px;
    border: 1px solid var(--border);
    backdrop-filter: blur(20px);
    transition: all 0.4s ease;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
}

.timeline-content:hover {
    transform: translateY(-12px);
    box-shadow: 0 30px 60px var(--glow-primary);
}

.timeline-date {
    color: var(--accent-primary);
    font-weight: 600;
    margin-bottom: 1rem;
    font-size: 0.95rem;
}

/* Social */
.social-section {
    margin-top: 5rem;
}

.social-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
}

.social-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem 1rem;
    background: var(--surface);
    border-radius: 20px;
    border: 1px solid var(--border);
    text-decoration: none;
    color: var(--text-secondary);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(10px);
}

.social-link:hover {
    transform: translateY(-20px) scale(1.05);
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    color: var(--bg-primary);
    box-shadow: 0 30px 60px var(--glow-primary);
}

.social-link i {
    font-size: 2.5rem;
    margin-bottom: 0.8rem;
}

/* Contact */
.contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
}

.contact-card, .contact-form {
    background: var(--surface);
    padding: 3rem;
    border-radius: 24px;
    border: 1px solid var(--border);
    backdrop-filter: blur(20px);
}

.contact-card h3 {
    margin-bottom: 2rem;
    color: var(--accent-primary);
}

.contact-item {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
    transition: all 0.3s ease;
}

.contact-item:hover {
    transform: translateX(10px);
}

.contact-icon {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: var(--bg-primary);
}

.form-group {
    margin-bottom: 2rem;
}

.form-group label {
    display: block;
    margin-bottom: 0.8rem;
    color: var(--text-secondary);
    font-weight: 500;
}

.form-input, .form-textarea {
    width: 100%;
    padding: 1.2rem 1.5rem;
    background: rgba(255, 255, 255, 0.02);
    border: 2px solid var(--border);
    border-radius: 16px;
    color: var(--text-primary);
    font-size: 1rem;
    font-family: inherit;
    transition: all 0.3s ease;
}

.form-input:focus, .form-textarea:focus {
    outline: none;
    border-color: var(--accent-primary);
    box-shadow: 0 0 0 4px var(--glow-primary);
}

.submit-btn {
    width: 100%;
    margin-top: 1rem;
}

/* Reveal Animations */
.reveal {
    opacity: 0;
    transform: translateY(60px);
    transition: all 1.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.reveal.active {
    opacity: 1;
    transform: translateY(0);
}

/* Responsive */
@media (max-width: 1024px) {
    .hero-content {
        grid-template-columns: 1fr;
        text-align: center;
        gap: 4rem;
    }
    
    .about-grid, .contact-grid {
        grid-template-columns: 1fr;
        gap: 3rem;
    }
    
    .timeline::before {
        left: 30px;
    }
    
    .timeline-item {
        flex-direction: column !important;
        padding-left: 4rem !important;
        padding-right: 0 !important;
    }
    
    .timeline-content {
        width: 100% !important;
    }
}

@media (max-width: 768px) {
    .profile-ring {
        width: 280px;
        height: 280px;
    }
    
    .profile-img {
        width: 260px;
        height: 260px;
    }
}

    </style>
